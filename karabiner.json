{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "F18 tap -> display sleep, hold -> system sleep",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f18",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "parameters": {
                                    "basic.to_if_alone_timeout_milliseconds": 500,
                                    "basic.to_if_held_down_threshold_milliseconds": 500
                                },
                                "to_if_alone": [
                                    {
                                        "shell_command": "/usr/bin/pmset displaysleepnow",
                                        "repeat": false
                                    }
                                ],
                                "to_if_held_down": [
                                    {
                                        "shell_command": "/bin/sh \"$HOME/.config/karabiner/scripts/system-sleep.sh\"",
                                        "repeat": false
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "F24 -> repo auto-backup sync",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f24",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "shell_command": "/bin/sh \"$HOME/.config/karabiner/scripts/repo-sync.sh\"" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}
